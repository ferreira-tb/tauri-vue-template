{
  "name": "tauri-vue-template",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "license": "GPL-3.0-only",
  "private": true,
  "scripts": {
    "build": "cargo +nightly -Zscript scripts/build-app.rs",
    "clean": "cargo +nightly -Zscript scripts/clean.rs",
    "clippy": "cargo +nightly -Zscript scripts/run-clippy.rs",
    "dev": "cargo tauri dev",
    "format": "dprint fmt && cargo fmt --all",
    "lint": "eslint . --config eslint.config.ts",
    "preview": "cargo +nightly -Zscript scripts/build-app.rs --preview",
    "type-check": "pnpm run -r --bail type-check",
    "udeps": "cargo +nightly udeps"
  },
  "dependencies": {
    "@lucide/vue": "=1.8.0",
    "@tauri-apps/api": "=2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "=2.3.2",
    "@tauri-apps/plugin-dialog": "=2.7.0",
    "@tauri-apps/plugin-fs": "=2.5.0",
    "@tauri-apps/plugin-opener": "=2.5.3",
    "@tauri-apps/plugin-os": "=2.3.2",
    "@tauri-apps/plugin-process": "=2.3.1",
    "@tauri-apps/plugin-updater": "=2.10.1",
    "@tauri-store/pinia": "=4.2.0",
    "@tb-dev/utils": "=7.3.18",
    "@tb-dev/vue": "=4.0.20",
    "@tb-dev/vue-components": "=7.1.17",
    "@tb-dev/vue-sonner": "=1.0.0",
    "@vueuse/core": "=14.2.1",
    "@vueuse/math": "=14.2.1",
    "@vueuse/router": "=14.2.1",
    "date-fns": "=4.1.0",
    "es-toolkit": "=1.45.1",
    "pinia": "=3.0.4",
    "reka-ui": "=2.9.6",
    "tw-animate-css": "=1.4.0",
    "vue": "=3.5.32",
    "vue-router": "=5.0.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "=4.2.3",
    "@tauri-apps/cli": "=2.10.1",
    "@tb-dev/eslint-config": "=10.0.7",
    "@types/node": "=25.6.0",
    "@vitejs/plugin-vue": "=6.0.6",
    "eslint": "=10.2.1",
    "tailwindcss": "=4.2.3",
    "tslib": "=2.8.1",
    "typescript": "=6.0.3",
    "vite": "=8.0.9",
    "vue-tsc": "=3.2.7"
  }
}
