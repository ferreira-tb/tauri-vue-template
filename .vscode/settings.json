{
  "[powershell]": {
    "editor.defaultFormatter": "ms-vscode.powershell"
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit"
  },
  "editor.defaultFormatter": "dprint.dprint",
  "editor.formatOnSave": true,
  "eslint.codeActionsOnSave.mode": "problems",
  "eslint.useFlatConfig": true,
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "files.eol": "\n",
  "git.branchProtection": ["main"],
  "git.branchProtectionPrompt": "alwaysPrompt",
  "rust-analyzer.cargo.targetDir": true,
  "rust-analyzer.linkedProjects": [
    "./Cargo.toml",
    "./scripts/build-app.rs",
    "./scripts/clean.rs",
    "./scripts/run-clippy.rs"
  ],
  "workbench.editor.customLabels.patterns": {
    "**/App.vue": "${dirname}/App.vue",
    "**/build.rs": "${dirname}/build.rs",
    "**/Cargo.toml": "${dirname}/Cargo.toml",
    "**/index.ts": "${dirname}/index.ts",
    "**/index.vue": "${dirname}/index.vue",
    "**/mod.rs": "${dirname}/mod.rs",
    "**/package.json": "${dirname}/package.json",
    "**/tsconfig.json": "${dirname}/tsconfig.json",
    "*/*/**/lib.rs": "${dirname(1)}/lib.rs",
    "*/*/**/main.rs": "${dirname(1)}/main.rs",
    "*/Cargo.toml": "<workspace>/Cargo.toml",
    "*/package.json": "<workspace>/package.json",
    "*/tsconfig.json": "<workspace>/tsconfig.json"
  }
}
